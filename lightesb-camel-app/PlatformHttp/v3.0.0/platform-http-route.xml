<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns="http://camel.apache.org/schema/spring">

    <!-- 订单数据转换路由 -->
    <!-- <route id="order-transform-route"  routePolicyRef="serviceContextRoutePolicy" description="订单数据转换服务"> -->
     <route id="order-transform-route"  description="订单数据转换服务">
        <!-- HTTP端点：接收订单数据 -->
        <from uri="undertow:http://0.0.0.0:{{server.port}}/{{service.version}}/transform/order?httpMethodRestrict=POST" />
        
         <process ref="requestCharsetProcessor"/> 
         <to uri="servicelog:debug?message=debug请求体：${body}"/>
        <!-- 记录请求日志 -->
        <!-- 获取请求头参数：https://camel.apache.org/components/4.14.x/languages/mvel-language.html#_variables-->
        <to uri="servicelog:info?message=订单转换服务监听地址：${header.CamelHttpUrl}，请求方法：${header.CamelHttpMethod}，请求头：${headers}，请求体：${body}"/>
        <!-- <log message="请求体：${body}"/> -->
        
        <!-- 方式1：使用JSONPath表达式提取orderId -->
        <log message="orderId (JSONPath): ${jsonpath($.orderId)}"/>
        
        <!-- 方式2：先设置到属性中，再打印 -->
        <setProperty name="extractedOrderId">
            <jsonpath>$.orderId</jsonpath>
        </setProperty>
        <log message="orderId (属性): ${exchangeProperty.extractedOrderId}"/>
        
        <!-- 方式3：使用JSONPath提取到Header中 -->
        <setHeader name="OrderId">
            <jsonpath>$.orderId</jsonpath>
        </setHeader>
        <log message="orderId (Header): ${header.OrderId}"/>
    
        <!--
        使用 JSONPath: ${jsonpath($.fieldName)} 是标准方式
        支持嵌套: ${jsonpath($.customer.name)}
        支持数组: ${jsonpath($.items[0].price)}
        条件判断: 可以在 <when> 条件中使用
        错误处理: 添加 suppressExceptions="true" 避免字段不存在时报错
        -->

        <transform>
            <simple>{"status": "success", "message": "请求处理完成"}</simple>
        </transform>
        
        <log message="订单转换完成: ${body}" />
                <!-- 记录响应日志（包含结果） -->
        <to uri="servicelog:info?message=订单转换完成&amp;showBody=true&amp;maxBodyLength=2000" />
         <!-- 处理响应的UTF-8编码和Content-Type -->
        <process ref="jsonResponseProcessor"/> 
        <!-- 设置响应头 -->
        <setHeader name="Content-Type">
            <constant>application/json</constant>
        </setHeader>
    </route>

  <!-- 订单数据转换路由 -->
    <route id="order-transform-route200" description="订单数据转换服务">
        <!-- HTTP端点：接收订单数据 -->
        <from uri="undertow:http://0.0.0.0:{{server.port}}/{{service.version}}/transform/order1?httpMethodRestrict=POST" />
        
        <transform>
            <simple>{"status": "${jsonpath($.orderId)}", "message": "请求处理完成"}</simple>
        </transform>
        
        <log message="订单转换完成: ${body}" />
                <!-- 记录响应日志（包含结果） -->
        <to uri="servicelog:info?message=订单转换完成&amp;showBody=true&amp;maxBodyLength=2000" />
         <!-- 处理响应的UTF-8编码和Content-Type -->
        <process ref="jsonResponseProcessor"/> 
        <!-- 设置响应头 -->
        <setHeader name="Content-Type">
            <constant>application/json</constant>
        </setHeader>
    </route>

</routes>
